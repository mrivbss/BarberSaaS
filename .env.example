VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
VITE_PUBLIC_APP_URL=http://localhost:5173

# Sólo para scripts locales; nunca usar prefijo VITE_ con esta clave.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
SEED_DEFAULT_ROLE=barbero
SEED_BARBERIA_SLUG=barberia-principal
# Sólo para una ejecución remota deliberada de los scripts seed.
ALLOW_REMOTE_SEED=false
CONFIRM_PROJECT_REF=

# Entorno local de la Edge Function (sin prefijo VITE_).
ALLOWED_ORIGINS=http://localhost:5173
